# ArchonVII repos are "depless" by default: `test` is `node --test` with zero
# dependencies. Disable lockfile generation so an accidental `npm install` can't
# leave a stray, meaningless package-lock.json (it would lock zero packages and is
# neither committed-by-design nor gitignored).
#
# If this repo later adds real npm dependencies, DELETE this file so npm writes a
# package-lock.json that you then commit for reproducible installs.
#
# Source: npm config `package-lock` — https://docs.npmjs.com/cli/v10/using-npm/config#package-lock
package-lock=false
