#!/usr/bin/env bash
#
# pre-commit — Repo-template baseline (F18, ArchonVII/repo-template#16).
#
# Single purpose: keep commits reviewable:
#   - block commits where a staged path also has unstaged worktree changes;
#   - block direct commits to the default branch, except for the narrow Owner
#     Maintenance Lane.
#
# This hook gates on the *branch*, not on individual commands. The branch
# check is unambiguous and has no echo/find/printf bypass.
#
# Bypass (logged to .agent/bypass.log so it leaves an audit trail):
#
#   ALLOW_PARTIAL_COMMIT=1 git commit ...
#   ALLOW_MAIN_COMMIT=1 git commit ...
#
# Rebase / merge / cherry-pick states are exempt — we don't want to
# break a `git rebase <default-branch>` or `git pull --rebase` during
# legitimate maintenance.
#
# Authority: docs/adr/001-primary-checkout-worktree-policy.md and AGENTS.md
# "Owner Maintenance Lane".

set -euo pipefail

hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=.githooks/scripts/owner-maintenance.sh
source "${hook_dir}/scripts/owner-maintenance.sh"
# shellcheck source=.githooks/scripts/checkout-role.sh
source "${hook_dir}/scripts/checkout-role.sh"

log_pre_commit_bypass() {
    local kind="$1"
    local detail="${2:-}"
    local repo_root
    repo_root="$(git rev-parse --show-toplevel)"
    local agent_dir="${repo_root}/.agent"
    mkdir -p "${agent_dir}"

    # Best-effort forensic metadata — none of these are fatal if missing.
    local ts who branch_name head_sha diff_stat
    ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    who="$(git config user.email 2>/dev/null || echo unknown)"
    branch_name="$(git symbolic-ref --short -q HEAD || echo HEAD)"
    head_sha="$(git rev-parse --short HEAD 2>/dev/null || echo unknown)"
    diff_stat="$(git diff --cached --shortstat 2>/dev/null || echo '(no stat)')"

    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
        "${ts}" "${kind}" "${who}" "${branch_name}" "${head_sha}" "${diff_stat}" "${detail}" \
        >> "${agent_dir}/bypass.log"
}

staged_paths_with_unstaged_changes() {
    local path
    declare -A staged_paths=()

    while IFS= read -r -d '' path; do
        [[ -n "${path}" ]] || continue
        staged_paths["${path}"]=1
    done < <(git diff --cached --name-only -z --diff-filter=ACMRTD 2>/dev/null || true)

    while IFS= read -r -d '' path; do
        [[ -n "${path}" ]] || continue
        if [[ -n "${staged_paths[${path}]+x}" ]]; then
            printf '%s\n' "${path}"
        fi
    done < <(git diff --name-only -z --diff-filter=ACMRTD 2>/dev/null || true)
}

# --- Detect in-progress git operations and skip the branch check -------
# During rebase/merge/cherry-pick, HEAD may transiently be on the default branch
# though the user isn't authoring a fresh commit there.
git_dir="$(git rev-parse --git-dir)"
for marker in MERGE_HEAD REBASE_HEAD CHERRY_PICK_HEAD; do
    if [[ -f "${git_dir}/${marker}" ]]; then
        exit 0
    fi
done
# git-rebase also uses these directory markers depending on mode.
if [[ -d "${git_dir}/rebase-merge" ]] || [[ -d "${git_dir}/rebase-apply" ]]; then
    exit 0
fi

# --- Staged/worktree overlap guard ------------------------------------
# If a path is staged and still dirty in the worktree, the commit snapshot is
# stale relative to disk. This catches format-on-edit and lint-fix output before
# a commit object exists.
overlap_paths="$(staged_paths_with_unstaged_changes)"
if [[ -n "${overlap_paths}" ]]; then
    if [[ "${ALLOW_PARTIAL_COMMIT:-0}" == "1" ]]; then
        overlap_one_line="$(printf '%s' "${overlap_paths}" | tr '\n' ',' | sed 's/,$//')"
        log_pre_commit_bypass "ALLOW_PARTIAL_COMMIT" "${overlap_one_line}"
        echo "[pre-commit] ALLOW_PARTIAL_COMMIT=1 — staged/worktree overlap bypass logged to .agent/bypass.log" >&2
    else
        cat >&2 <<EOF
[pre-commit] Refusing to commit: staged path(s) still have unstaged worktree changes.

These paths are staged, but the files on disk differ from the staged snapshot:
$(printf '%s\n' "${overlap_paths}" | sed 's/^/  - /')

This often means a formatter or fixer ran after staging. Re-run formatting if
needed, then re-stage the path(s) before committing:
  git add -- <path>

For an intentional partial commit, override with an audit trail:
  ALLOW_PARTIAL_COMMIT=1 git commit ...
EOF
        exit 1
    fi
fi

# --- Branch check ------------------------------------------------------
# git symbolic-ref resolves the branch name even on an unborn branch (a fresh
# repo's first commit), where `git rev-parse --abbrev-ref HEAD` prints "HEAD" to
# stdout AND exits non-zero — which would otherwise double to "HEAD\nHEAD" and
# trip the worktree guard. -q yields empty + rc1 on a genuinely detached HEAD,
# so the `|| echo HEAD` fallback still fires for the detached case below.
branch="$(git symbolic-ref --short -q HEAD || echo HEAD)"

# Detached HEAD is fine — typically a checkout of a tag or SHA, not a direct
# default-branch commit.
if [[ "${branch}" == "HEAD" ]]; then
    exit 0
fi

# --- Worktree guard (ADR-001) ------------------------------------------
# The primary checkout is the stable lane: it stays on the default branch.
# Feature work belongs in a linked worktree. A feature-branch commit in the
# primary checkout is the failure mode this guard exists to stop.
default_branch="$(checkout_default_branch)"
if checkout_is_primary && [[ "${branch}" != "${default_branch}" ]]; then
    if [[ "${ALLOW_PRIMARY_FEATURE_COMMIT:-0}" == "1" ]]; then
        log_pre_commit_bypass "ALLOW_PRIMARY_FEATURE_COMMIT"
        echo "[pre-commit] ALLOW_PRIMARY_FEATURE_COMMIT=1 — bypass logged to .agent/bypass.log" >&2
    else
        cat >&2 <<EOF
[pre-commit] Feature commits are blocked in the primary checkout.

You are on '${branch}' in the primary checkout. The primary checkout stays on
'${default_branch}'; feature work happens in a linked worktree.

Create one and commit from there instead:
  git worktree add -b ${branch} ../<repo>-<issue>-<slug>

(If '${branch}' already exists, drop the '-b'.) See AGENTS.md, section
"Checkout role / worktrees".

Override with an audit trail only if you truly mean to:
  ALLOW_PRIMARY_FEATURE_COMMIT=1 git commit ...
EOF
        exit 1
    fi
fi

# Non-default branches in a linked worktree are the normal feature path.
if [[ "${branch}" != "${default_branch}" ]]; then
    exit 0
fi

if owner_maintenance_staged_paths_safe; then
    echo "[pre-commit] Owner Maintenance Lane — add-only safe maintenance paths allowed on ${branch}." >&2
    exit 0
fi

if [[ "${ALLOW_MAIN_COMMIT:-0}" != "1" ]]; then
    cat >&2 <<EOF
[pre-commit] Direct commits to '${branch}' are blocked.

Create a linked worktree and open a PR from there instead:
  git worktree add -b <type>/<short-description> ../<repo>-<issue>-<slug>
Keep the primary checkout on '${branch}'. See AGENTS.md "Checkout role / worktrees".

Owner Maintenance Lane direct commits are allowed only when every staged path
is add-only and safe (docs/**, image files, or .changelog), or is a named
append-log ledger (.claude/noticed.md, .claude/napkin.md,
.claude/friction.md, docs/decisions/decision-log.md — these may also be
modified). Other unsafe files, deletes, renames, and copies require the normal
issue -> branch -> PR lifecycle.

If you really need to commit here (e.g. Release-Admiral fixup, F11),
bypass with an audit trail:
  ALLOW_MAIN_COMMIT=1 git commit ...

See .githooks/pre-commit (F18, repo-template#16) for the rule source.
EOF
    exit 1
fi

# --- Bypass: log the override to .agent/bypass.log ---------------------
log_pre_commit_bypass "ALLOW_MAIN_COMMIT"

echo "[pre-commit] ALLOW_MAIN_COMMIT=1 — bypass logged to .agent/bypass.log" >&2
exit 0
